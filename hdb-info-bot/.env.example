# --- Required ---
# Telegram bot token from @BotFather. See README section "1a. Telegram bot token".
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# --- Recommended (data.gov.sg works without a key today but is rate-limited harder without one) ---
# See README section "1b. data.gov.sg API key".
DATA_GOV_SG_API_KEY=your-data-gov-sg-api-key-here

# --- Optional (bot degrades to text-only stats, no map images, if this is unset) ---
# See README section "1c. Google Maps API key (Static Maps + Geocoding)".
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- Runtime mode ---
# polling: long-polling, no public URL needed. Use this for the Oracle Cloud VM.
# webhook: needs WEBHOOK_URL + PORT. Use this for Google Cloud Run.
RUN_MODE=polling

# --- Only needed when RUN_MODE=webhook ---
# Public HTTPS base URL of the deployed service, e.g. https://hdb-info-bot-xxxx.a.run.app
WEBHOOK_URL=
# Port to listen on. Cloud Run sets this automatically; default 8080 works locally too.
PORT=8080

# --- Tuning (sensible defaults, usually leave alone) ---
RECENT_MONTHS_WINDOW=12
# How many months of history the "Compare Districts" chart plots. This
# feature needs no Google Maps key — the chart is rendered locally.
CHART_MONTHS_WINDOW=24
# How often the background job re-checks data.gov.sg for updated datasets.
# HDB's resale/rental datasets are republished monthly at most, so there's
# nothing to gain from checking more often than every few months -- each
# check that finds a real change also re-ingests the local SQLite cache,
# which briefly costs a few seconds of CPU. Default: 4320h = ~6 months.
SYNC_INTERVAL_HOURS=4320
# Where the downloaded dataset CSVs are cached. Defaults to ./data next to
# the hdb_bot package (i.e. hdb-info-bot/data/) if left blank.
DATA_DIR=
